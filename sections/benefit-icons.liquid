{{ 'section-benefit-icons.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign benefits = product.metafields.custom.benefits.value
  assign use_metaobjects = false
  if benefits != blank and benefits.size > 0
    assign use_metaobjects = true
  endif
-%}

<div class="benefit-icons color-{{ section.settings.color_scheme }} gradient">
  <div class="benefit-icons__inner page-width section-{{ section.id }}-padding">
    <ul class="benefit-icons__grid" role="list">
      {%- if use_metaobjects -%}
        {%- for benefit in benefits -%}
          <li class="benefit-icons__item">
            {%- render 'benefit-icon', icon: benefit.icon.value -%}
            <span class="benefit-icons__label">{{ benefit.title.value | escape }}</span>
            {%- if benefit.description.value != blank -%}
              <span class="benefit-icons__desc">{{ benefit.description.value | escape }}</span>
            {%- endif -%}
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <li class="benefit-icons__item" {{ block.shopify_attributes }}>
            {%- render 'benefit-icon', icon: block.settings.icon -%}
            <span class="benefit-icons__label">{{ block.settings.title | escape }}</span>
            {%- if block.settings.description != blank -%}
              <span class="benefit-icons__desc">{{ block.settings.description | escape }}</span>
            {%- endif -%}
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Benefit Icons",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Wenn das Produkt-Metafeld custom.benefits (Metaobjekte) gepflegt ist, wird dieses verwendet. Sonst dienen die folgenden Bloecke als Fallback."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-2"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Schild" },
            { "value": "flask", "label": "Labor" },
            { "value": "dna", "label": "DNA" },
            { "value": "leaf", "label": "Blatt" },
            { "value": "drop", "label": "Tropfen" },
            { "value": "germany", "label": "Deutschland" },
            { "value": "check", "label": "Haken" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Benefit"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Beschreibung (optional)"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "Benefit Icons",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "shield", "title": "Omega-Schutz" } },
        { "type": "benefit", "settings": { "icon": "flask", "title": "Laborzertifiziert" } },
        { "type": "benefit", "settings": { "icon": "dna", "title": "Gentechnikfrei" } },
        { "type": "benefit", "settings": { "icon": "leaf", "title": "Vegan" } },
        { "type": "benefit", "settings": { "icon": "drop", "title": "Omega-3-reich" } },
        { "type": "benefit", "settings": { "icon": "germany", "title": "Herstellung in Deutschland" } }
      ]
    }
  ]
}
{% endschema %}
