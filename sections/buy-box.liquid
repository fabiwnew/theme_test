{{ 'section-buy-box.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
  assign subtitle = product.metafields.buyBox.subtitle.value
  assign product_form_id = 'buy-box-form-' | append: section.id
-%}

<div class="buy-box color-{{ section.settings.color_scheme }} gradient">
  <div class="buy-box__inner page-width section-{{ section.id }}-padding">
    <div class="buy-box__media">
      {%- render 'image-slider', product: product -%}
    </div>

    <div class="buy-box__info">
      <h1 class="buy-box__title">{{ product.title | escape }}</h1>

      {%- if subtitle != blank -%}
        <p class="buy-box__subtitle">{{ subtitle }}</p>
      {%- endif -%}

      <div class="buy-box__pricing">
        <div class="buy-box__prices">
          {%- if on_sale -%}
            <span class="buy-box__compare">{{ current_variant.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="buy-box__price{% if on_sale %} buy-box__price--sale{% endif %}">
            {{ current_variant.price | money }}
          </span>
        </div>
        <span class="buy-box__tax">{{ 'products.product.buybox.mwst_label' | t }}</span>
      </div>

      {%- if product.available -%}
        <p class="buy-box__availability">
          <span class="buy-box__availability-dot" aria-hidden="true"></span>
          {{ 'products.product.buybox.availability_label' | t }}
        </p>
      {%- endif -%}

      <product-form class="buy-box__form-wrapper" data-hide-errors="false">
        <div class="product-form__error-message-wrapper" role="alert" hidden>
          <span class="product-form__error-message"></span>
        </div>

        {%- form 'product',
          product,
          id: product_form_id,
          class: 'buy-box__form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <input
            type="hidden"
            name="id"
            value="{{ current_variant.id }}"
            disabled
            class="product-variant-id"
          >
          <button
            type="submit"
            name="add"
            class="buy-box__atc button"
            {% unless product.available %}disabled{% endunless %}
          >
            <span>
              {%- if product.available -%}
                {{ 'products.product.buybox.add_to_cart_label' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </span>
            {%- render 'icon-cart-blick' -%}
            <div class="loading-overlay__spinner hidden">
              <svg
                aria-hidden="true"
                focusable="false"
                class="spinner"
                viewBox="0 0 66 66"
                xmlns="http://www.w3.org/2000/svg"
              >
                <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
              </svg>
            </div>
          </button>
        {%- endform -%}
      </product-form>
    </div>
  </div>
</div>

<script src="{{ 'selling-plans.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Buy Box",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "Buy Box"
    }
  ]
}
{% endschema %}
