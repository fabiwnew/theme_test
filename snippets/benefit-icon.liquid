{% comment %}
  Renders an inline SVG benefit icon from a key, so there is no extra request
  per icon. The color follows the surrounding text color via currentColor,
  which the Benefit Icons section drives from its "Icon color" setting.

  Accepts:
  - icon: {String} icon key (shield, flask, microscope, leaf, drop,
    germany-silhouette). Unknown/blank keys fall back to a check mark.

  Usage:
  {% render 'benefit-icon', icon: 'shield' %}
{% endcomment %}

{%- liquid
  assign key = icon | default: 'check' | downcase | strip
-%}

<span class="benefit-icon" aria-hidden="true">
  {%- case key -%}
    {%- when 'shield' -%}
      <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12.4839 1.25C15.4037 3.83322 19.2145 5.17821 23.1089 5C23.6759 6.92877 23.8494 8.95183 23.6191 10.949C23.3888 12.9461 22.7593 14.8766 21.7682 16.6257C20.777 18.3747 19.4444 19.9067 17.8495 21.1306C16.2546 22.3545 14.4299 23.2453 12.4839 23.75C10.5379 23.2453 8.71327 22.3545 7.11836 21.1306C5.52344 19.9067 4.19081 18.3747 3.19967 16.6257C2.20853 14.8766 1.57909 12.9461 1.34877 10.949C1.11844 8.95183 1.29193 6.92877 1.85892 5C5.75333 5.17821 9.56413 3.83322 12.4839 1.25Z" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    {%- when 'flask' -%}
      <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.4995 7.55L7.34696 22.705C7.01537 23.0367 6.6217 23.2998 6.18843 23.4793C5.75516 23.6588 5.29077 23.7513 4.82177 23.7513C3.8746 23.7514 2.96617 23.3753 2.29633 22.7056C1.62649 22.036 1.25012 21.1276 1.25 20.1804C1.24988 19.2333 1.62603 18.3248 2.29571 17.655L17.4482 2.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M6.24939 13.75H16.2494" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M21.2494 16.25L23.1244 18.25C23.4426 18.6108 23.65 19.0558 23.7216 19.5316C23.7931 20.0074 23.7259 20.4937 23.528 20.9322C23.33 21.3707 23.0098 21.7428 22.6056 22.0038C22.2014 22.2648 21.7305 22.4036 21.2494 22.4036C20.7683 22.4036 20.2974 22.2648 19.8932 22.0038C19.489 21.7428 19.1687 21.3707 18.9708 20.9322C18.7728 20.4937 18.7056 20.0074 18.7772 19.5316C18.8488 19.0558 19.0562 18.6108 19.3744 18.25L21.2494 16.25Z" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
