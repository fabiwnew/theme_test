    {%- when 'germany-silhouette' -%}
      <svg width="25" height="34" viewBox="0 0 25 34" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10.0594 1.42529C10.2234 1.95896 10.5782 2.41554 11.0614 2.70166L12.58 3.6001C12.5808 4.4258 13.1719 5.18371 14.0507 5.32471L14.4579 5.39014C15.1021 5.4935 15.7577 5.28828 16.2274 4.83545L18.1766 2.95459L18.1844 2.95557L19.3446 3.95068C19.5413 4.11932 19.7656 4.25291 20.0077 4.34521L21.1552 4.78174L21.5458 6.4624L21.2098 7.67529C20.9661 8.55447 21.2774 9.49359 21.9979 10.0532L22.4989 10.4429L22.8495 14.1772C22.8878 14.5851 23.0367 14.9747 23.2802 15.3042L23.6903 15.8599L23.6151 16.1099C23.2046 16.0872 22.7956 16.1792 22.4354 16.3794L22.2499 16.4946L18.1932 19.3149C16.8604 19.437 16.0318 20.8816 16.6581 22.1108L17.9686 24.6821C18.119 24.9773 18.3328 25.2359 18.5946 25.439L20.7343 27.0981L18.9706 28.2847C18.3121 28.7274 17.9355 29.4846 17.9794 30.2769L17.993 30.5396L16.036 30.7808C15.6778 30.8248 15.3365 30.9547 15.0399 31.1577L14.9159 31.2485L14.5458 31.5405L13.4354 31.2632C12.799 31.104 12.1387 31.275 11.662 31.6938L10.7186 31.1235L10.5282 31.021C10.3341 30.9278 10.1272 30.8631 9.91394 30.8286L8.17566 30.5474L7.995 30.5259C7.8744 30.5163 7.75326 30.516 7.63269 30.5259L7.45105 30.5483L6.17761 30.7563L5.22058 30.5698L5.85144 27.9976L6.10925 27.6948C7.15707 26.4575 6.59188 24.5514 5.03894 24.0854L3.8866 23.7397L3.81238 23.7183L3.73718 23.7056L2.62097 23.5142L1.85437 22.6636L1.59753 20.687C2.05269 20.1605 2.16984 19.3994 1.85535 18.7456L1.26746 17.5229L1.83875 15.6792C1.98069 15.2202 1.97139 14.7276 1.81335 14.2739L1.78601 14.1968C2.00405 14.1077 2.2067 13.9795 2.38171 13.8159L3.78015 12.5083C4.13501 12.1766 4.3733 11.7394 4.45886 11.2612L4.94031 8.56592C4.9835 8.32406 4.98682 8.07642 4.95007 7.8335L4.71863 6.30029L4.72253 6.29346L5.60242 6.21631L6.46179 6.73486C7.43071 7.31848 8.59853 6.59506 8.61707 5.55518C9.62586 5.22439 10.0676 3.96227 9.44128 3.07373L9.27722 1.29834L10.0594 1.42529Z" stroke="currentColor" stroke-width="2.5"/>
      </svg>
    {%- else -%}
      <svg width="25" height="25" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2.5 13L9.5 20L22.5 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
